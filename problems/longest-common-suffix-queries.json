  "solution_html": "<div class=\"lc-section\"><h3 style=\"margin:0 0 12px 0;color:var(--lc-success);\">✅ 完整解法</h3><pre style=\"background:rgba(0,0,0,0.05);padding:12px;border-radius:8px;overflow-x:auto;line-height:1.6;\"><code class=\"language-python\">from typing import List\n\nclass TrieNode:\n    def __init__(self):\n        self.children = {}\n        self.best_idx = -1  # 通過此節點的最佳候選索引\n\nclass Solution:\n    def stringIndices(self, wordsContainer: List[str], wordsQuery: List[str]) -> List[int]:\n        root = TrieNode()\n\n        for i, word in enumerate(wordsContainer):\n            node = root\n            # 更新根節點(處理與任何字串皆無公共後綴的情況)\n            if root.best_idx == -1 or len(word) < len(wordsContainer[root.best_idx]):\n                root.best_idx = i\n\n            # 反轉字串後插入 Trie，將後綴匹配轉換為前綴匹配\n            for ch in reversed(word):\n                if ch not in node.children:\n                    node.children[ch] = TrieNode()\n                node = node.children[ch]\n                # 維護每個節點：長度最短(相同長度則索引最小)的候選\n                if node.best_idx == -1 or len(word) < len(wordsContainer[node.best_idx]):\n                    node.best_idx = i\n\n        result = []\n        for query in wordsQuery:\n            node = root\n            for ch in reversed(query):\n                if ch not in node.children:\n                    break  # 後綴無法再延伸，停在當前節點\n                node = node.children[ch]\n            result.append(node.best_idx)\n\n        return result\n</code></pre><h4 style=\"margin:16px 0 8px 0;color:var(--lc-primary);\">📖 程式碼走查（Example 1）</h4><svg viewBox=\"0 0 600 200\" xmlns=\"http://www.w3.org/2000/svg\" style=\"width:100%;height:auto;display:block;margin:8px 0;\"><text x=\"10\" y=\"16\" fill=\"var(--lc-text)\" font-size=\"11\" font-weight=\"700\">wordsContainer = [&#34;abcd&#34;(idx0,len4), &#34;bcd&#34;(idx1,len3), &#34;xbcd&#34;(idx2,len4)]</text><text x=\"10\" y=\"32\" fill=\"var(--lc-muted)\" font-size=\"11\">反轉後插入Trie: &#34;dcba&#34;, &#34;dcb&#34;, &#34;dcbx&#34; → 三者共同前綴 &#34;dcb&#34;</text><circle cx=\"80\" cy=\"65\" r=\"22\" fill=\"rgba(91,141,239,0.15)\" stroke=\"var(--lc-primary)\" stroke-width=\"2\"/><text x=\"80\" y=\"62\" text-anchor=\"middle\" fill=\"var(--lc-primary)\" font-size=\"10\" font-weight=\"700\">root</text><text x=\"80\" y=\"75\" text-anchor=\"middle\" fill=\"var(--lc-success)\" font-size=\"10\">best=1</text><line x1=\"102\" y1=\"65\" x2=\"148\" y2=\"65\" stroke=\"var(--lc-border)\" stroke-width=\"1.5\"/><text x=\"122\" y=\"58\" text-anchor=\"middle\" fill=\"var(--lc-muted)\" font-size=\"11\">d</text><circle cx=\"170\" cy=\"65\" r=\"22\" fill=\"rgba(91,141,239,0.15)\" stroke=\"var(--lc-primary)\" stroke-width=\"2\"/><text x=\"170\" y=\"62\" text-anchor=\"middle\" fill=\"var(--lc-primary)\" font-size=\"10\" font-weight=\"700\">[d]</text><text x=\"170\" y=\"75\" text-anchor=\"middle\" fill=\"var(--lc-success)\" font-size=\"10\">best=1</text><line x1=\"192\" y1=\"65\" x2=\"238\" y2=\"65\" stroke=\"var(--lc-border)\" stroke-width=\"1.5\"/><text x=\"212\" y=\"58\" text-anchor=\"middle\" fill=\"var(--lc-muted)\" font-size=\"11\">c</text><circle cx=\"260\" cy=\"65\" r=\"22\" fill=\"rgba(91,141,239,0.15)\" stroke=\"var(--lc-primary)\" stroke-width=\"2\"/><text x=\"260\" y=\"62\" text-anchor=\"middle\" fill=\"var(--lc-primary)\" font-size=\"10\" font-weight=\"700\">[c]</text><text x=\"260\" y=\"75\" text-anchor=\"middle\" fill=\"var(--lc-success)\" font-size=\"10\">best=1</text><line x1=\"282\" y1=\"65\" x2=\"328\" y2=\"65\" stroke=\"var(--lc-border)\" stroke-width=\"1.5\"/><text x=\"302\" y=\"58\" text-anchor=\"middle\" fill=\"var(--lc-muted)\" font-size=\"11\">b</text><circle cx=\"350\" cy=\"65\" r=\"22\" fill=\"rgba(91,141,239,0.15)\" stroke=\"var(--lc-primary)\" stroke-width=\"2\"/><text x=\"350\" y=\"62\" text-anchor=\"middle\" fill=\"var(--lc-primary)\" font-size=\"10\" font-weight=\"700\">[b]</text><text x=\"350\" y=\"75\" text-anchor=\"middle\" fill=\"var(--lc-success)\" font-size=\"10\">best=1</text><line x1=\"350\" y1=\"87\" x2=\"320\" y2=\"118\" stroke=\"var(--lc-border)\" stroke-width=\"1.5\"/><text x=\"325\" y=\"108\" fill=\"var(--lc-muted)\" font-size=\"10\">a(idx0)</text><circle cx=\"310\" cy=\"135\" r=\"18\" fill=\"rgba(91,141,239,0.1)\" stroke=\"var(--lc-border)\" stroke-width=\"1.5\"/><text x=\"310\" y=\"132\" text-anchor=\"middle\" fill=\"var(--lc-text)\" font-size=\"10\">[a]</text><text x=\"310\" y=\"145\" text-anchor=\"middle\" fill=\"var(--lc-muted)\" font-size=\"9\">best=0</text><line x1=\"350\" y1=\"87\" x2=\"390\" y2=\"118\" stroke=\"var(--lc-border)\" stroke-width=\"1.5\"/><text x=\"385\" y=\"108\" fill=\"var(--lc-muted)\" font-size=\"10\">x(idx2)</text><circle cx=\"400\" cy=\"135\" r=\"18\" fill=\"rgba(91,141,239,0.1)\" stroke=\"var(--lc-border)\" stroke-width=\"1.5\"/><text x=\"400\" y=\"132\" text-anchor=\"middle\" fill=\"var(--lc-text)\" font-size=\"10\">[x]</text><text x=\"400\" y=\"145\" text-anchor=\"middle\" fill=\"var(--lc-muted)\" font-size=\"9\">best=2</text><text x=\"450\" y=\"55\" fill=\"var(--lc-text)\" font-size=\"11\">查詢 &#34;cd&#34; → 反轉 &#34;dc&#34;</text><text x=\"450\" y=\"70\" fill=\"var(--lc-text)\" font-size=\"11\">root→[d]→[c]，沒有&#34;d&#34;後的下一字</text><text x=\"450\" y=\"85\" fill=\"var(--lc-success)\" font-size=\"11\" font-weight=\"700\">停在[c]節點，best=1 ✓</text><text x=\"450\" y=\"110\" fill=\"var(--lc-text)\" font-size=\"11\">查詢 &#34;xyz&#34; → 反轉 &#34;zyx&#34;</text><text x=\"450\" y=\"125\" fill=\"var(--lc-text)\" font-size=\"11\">root沒有&#34;z&#34;子節點 → break</text><text x=\"450\" y=\"140\" fill=\"var(--lc-success)\" font-size=\"11\" font-weight=\"700\">停在root，best=1 ✓</text></svg><h4 style=\"margin:16px 0 8px 0;color:var(--lc-primary);\">⏱️ 複雜度分析</h4><table style=\"width:100%;border-collapse:collapse;margin:8px 0;\"><tr style=\"background:rgba(91,141,239,0.1);\"><th style=\"padding:8px;border:1px solid var(--lc-border);text-align:left;\">指標</th><th style=\"padding:8px;border:1px solid var(--lc-border);text-align:left;\">複雜度</th><th style=\"padding:8px;border:1px solid var(--lc-border);text-align:left;\">原因</th></tr><tr><td style=\"padding:8px;border:1px solid var(--lc-border);\"><strong>時間</strong></td><td style=\"padding:8px;border:1px solid var(--lc-border);\"><code>O((N+Q)·L)</code></td><td style=\"padding:8px;border:1px solid var(--lc-border);\">N 條容器字串建樹各走 O(L)；Q 條查詢各走 O(L)；L 為最長字串長度</td></tr><tr><td style=\"padding:8px;border:1px solid var(--lc-border);\"><strong>空間</strong></td><td style=\"padding:8px;border:1px solid var(--lc-border);\"><code>O(N·L·Σ)</code></td><td style=\"padding:8px;border:1px solid var(--lc-border);\">Trie 最多 N·L 個節點，每節點最多 Σ=26 條邊(字典實作則近似 O(N·L))</td></tr></table><div style=\"background:rgba(255,200,0,0.12);padding:14px;border-radius:8px;border-left:4px solid var(--lc-warning);margin:16px 0;\"><strong>💡 Key Insight</strong><br><span style=\"line-height:1.6;\">將後綴問題反轉為前綴問題，再以 Trie 攤平查詢成本。每個節點在建樹時就記錄「最佳候選」，查詢階段只需 O(L) 走訪一次，不需任何比較 — 這是「預計算答案嵌入資料結構」的經典技巧。</span></div></div>"
}